{
  "name": "relay-gent",
  "version": "0.1.0",
  "description": "A CLI tool designed to watch a file its changes and relay the delta of those changes to a coding agent.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "relay-gent": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "build": "bunx tsc --noEmit && bun build ./src/index.ts --outdir ./dist --target bun && bun build ./bin/relay-gent.ts --outfile ./dist/cli.js --target bun",
    "prepublishOnly": "bun run build"
  },
  "license": "MIT",
  "author": "Jalen Evans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JalenEvans/relay-gent.git"
  },
  "homepage": "https://github.com/JalenEvans/relay-gent#readme",
  "bugs": {
    "url": "https://github.com/JalenEvans/relay-gent/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "bun-types": "latest",
    "fast-check": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.x",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "toml": "^5.0.0",
    "zod": "^3.23.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
